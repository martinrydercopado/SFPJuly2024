<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Due_Date_Must_Be_Future</fullName>
    <active>true</active>
    <description>Due Date must be in the future for new tickets</description>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;New&quot;),
    Due_Date__c &lt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>Due_Date__c</errorDisplayField>
    <errorMessage>Due Date must be in the future for new tickets</errorMessage>
</ValidationRule>
